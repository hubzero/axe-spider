# axe-spider site configuration
#
# Copy to axe-spider.yaml and edit for your site.
# Command-line arguments override config values.

# Default starting URL
url: https://example.com/

# WCAG level: wcag2a, wcag2aa, wcag21aa, wcag22aa, etc.
level: wcag21aa

# Maximum pages to crawl
max_pages: 50

# Output directory for reports
output_dir: ./reports

# Seconds to wait after page load for JS to settle
page_wait: 1

# Flush reports every N pages (partial results survive kills)
save_every: 25

# Restart browser every N pages to prevent Chromium memory leaks.
# Long scans accumulate DOM nodes, JS heaps, and image caches,
# causing slowdowns and occasional 60s+ hangs.
restart_every: 500

# Paths to exclude from scanning (prefix match)
exclude_paths:
  - /login
  - /api
  - /administrator

# Only scan URLs under these path prefixes (empty = scan everything)
# include_paths:
#   - /docs
#   - /help

# Regex patterns to exclude (e.g. paths behind HTTP basic auth)
# exclude_regex:
#   - ^/internal/[^/]+/(admin|settings|logs)(/|$)

# Query parameters to strip from URLs during normalization.
# Deduplicates sort/filter/pagination variants of the same page.
# Plain strings are stripped globally; dicts with path (regex) + params
# strip only on matching URL paths.
strip_query_params:
  - limit
  - limitstart
  - start
  - sort
  - sortby
  - sortdir
  - return
  - filterby
  - sharewith
  # Path-conditional: strip 'parent' and 'area' only on /tags and /resources
  # - path: ^/(tags|resources)
  #   querystring: [parent, area]

# Process priority — keep the scan from starving production services.
# niceness: 0-19 (higher = lower priority, default 10; 0 to disable)
niceness: 10
# OOM killer score adjustment — higher = killed first (default 1000; 0 to disable)
oom_score_adj: 1000

# Allowlist of known-acceptable incompletes (see allowlist.yaml.example)
# allowlist: allowlist.yaml

# Custom instructions for the --llm report (path to a markdown file).
# Use this to give site-specific context like where templates live,
# what CSS preprocessor to use, coding conventions, etc.
# If not set, generic WCAG instructions are used.
# llm_instructions: llm-instructions.md

# Authentication — scan as a logged-in user to reach member-only pages.
# Credentials are in a separate file (not committed to git).
# auth:
#   credentials_file: ~/.axe-spider-creds   # username:password or two lines
#   login_url: /login                        # path to the login form
#   login_check: /members/myaccount          # URL that 200s when logged in
#   cookies_file: cookies.json               # saved session cookies

# Ignore robots.txt restrictions (default: obey robots.txt)
# ignore_robots: true

# Ignore TLS certificate errors (for self-signed internal sites)
# ignore_certificate_errors: true

# Browser driver: selenium (default) or playwright
# Playwright is ~2-3x faster and manages its own Chromium binary.
# Install: pip install playwright && playwright install chromium
# driver: playwright

# Chromium / ChromeDriver paths (selenium driver only)
chromium_path: /usr/bin/chromium-browser
chromedriver_path: /usr/bin/chromedriver
